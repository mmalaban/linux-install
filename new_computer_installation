#!/bin/bash

if [[ $EUID -ne 0 ]]; then
   echo "Error: This script must be run with sudo: \"sudo $0\""
   exit 1
fi

# Manually defined array of apps
# (Add or remove names here as needed)
apps=(
    "alacritty"
    "bat"
    "bat-extras"
    "btop"
    "fastfetch"
    "fzf"
    "git"
    "git-lfs"
    "neovim"
    "pdftk-java"
    "uv"
    "xclip"
)

# Detect the OS / Package Manager
if command -v dnf &> /dev/null; then
    PKG_MANAGER="dnf"
    INSTALL_CMD="sudo dnf install -y"
else
    echo "Error: dnf not found on this system."
    exit 1
fi

echo "--- Detected $PKG_MANAGER System ---"

# Install lazygit via COPR
if command -v lazygit &> /dev/null; then
    echo "[SKIP] 'lazygit' is already installed."
else
    echo "[INSTALLING] 'lazygit' via COPR..."
    sudo dnf copr enable -y dejan/lazygit
    sudo dnf install -y lazygit
fi

# Iterate through the array
for app in "${apps[@]}"; do
    # Check if the binary exists in the system PATH
    if command -v "$app" &> /dev/null; then
        echo "[SKIP] '$app' is already installed."
    else
        echo "[INSTALLING] '$app'..."
        # Execute the install command
        $INSTALL_CMD "$app"
    fi
done

echo "--- Installation complete ---"

